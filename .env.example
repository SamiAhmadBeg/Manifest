OPENAI_API_KEY=sk-proj-your-key-here

# Cortex Registered Developer app (Professional EEG: No for Basic BCI / fac).
# Requires Emotiv Launcher + approved app. Facial expressions use Basic License.
EMOTIV_CLIENT_ID=your-client-id-here
EMOTIV_CLIENT_SECRET=your-client-secret-here

# EMG gesture benchmarks (0–1 or percent 0–100). Jaw=enter, brow raise=exit.
# Basic License fac stream only (Professional EEG: No). Hysteresis/cooldown for smooth UX.
# BIOSIGNAL_JAW_THRESHOLD=10
# BIOSIGNAL_BROW_THRESHOLD=62
# BIOSIGNAL_COOLDOWN_MS=900
# BIOSIGNAL_CROSS_LOCK_MS=750
# BIOSIGNAL_RELEASE_HOLD_MS=280

# SSVEP flicker targets (home carousel look-left / look-right). Consensus on 60 Hz panels:
# NEXT_PUBLIC_SSVEP_LEFT_HZ=12
# NEXT_PUBLIC_SSVEP_RIGHT_HZ=15
